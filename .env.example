# ===== App =====
# URL pública do app (sem barra no fim). Usada no OAuth e na publicação do Instagram.
APP_URL=http://localhost:3000
# Segredo para assinar cookies de sessão (gere com: openssl rand -hex 32)
SESSION_SECRET=

# ===== Banco (Postgres gerenciado: Neon ou Supabase) =====
# Use a connection string COM POOLER (PgBouncer) p/ serverless na Vercel.
# Neon: ...-pooler.<region>.aws.neon.tech  | Supabase: porta 6543 (Transaction)
DATABASE_URL=

# ===== IA (Anthropic) — fica SÓ no servidor =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Bancos de imagem (opcionais, mas recomendados) =====
# Wikimedia/Wikipedia/Openverse não exigem chave.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ===== Armazenamento de assets (arte/fonte/logo) =====
# Vercel Blob: crie um store no painel e cole o token. Sem ele, assets viram data URL no DB (fallback).
BLOB_READ_WRITE_TOKEN=

# ===== Instagram Graph API (publicação legítima) =====
# App do Facebook (tipo Business) com produtos Instagram Graph + Facebook Login.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Limite de posts por canal em 24h (Graph API permite ~25–100).
IG_DAILY_LIMIT=25

# ===== Google Drive (ler ativos por pasta/canal) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
